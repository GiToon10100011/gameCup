# RAWG API base URL — optional override (기본값: https://api.rawg.io/api)
# 환경별 프록시 도입 또는 호스트 교체 시 본 값으로 재정의. 용도 상세는 docs/06-setup/rawg-api-key.md §5 참조.
NEXT_PUBLIC_RAWG_BASE_URL=https://api.rawg.io/api
# RAWG API key — required (Iteration 1+, see docs/06-setup/rawg-api-key.md)
NEXT_PUBLIC_RAWG_KEY=your_rawg_api_key_here

# Supabase — required for Iteration 4+ (Auth, DB, RLS)
# 획득: Supabase 대시보드 → Project Settings → API
# 설정 절차: docs/06-setup/supabase-setup.md
# NEXT_PUBLIC_SUPABASE_URL: "Project URL" 값 (예: https://xxxxxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
