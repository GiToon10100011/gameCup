# RAWG API base URL — optional override (기본값: https://api.rawg.io/api)
# 환경별 프록시 도입 또는 호스트 교체 시 본 값으로 재정의. 용도 상세는 docs/06-setup/rawg-api-key.md §5 참조.
NEXT_PUBLIC_RAWG_BASE_URL=https://api.rawg.io/api
# RAWG API key — required (Iteration 1+, see docs/06-setup/rawg-api-key.md)
NEXT_PUBLIC_RAWG_KEY=your_rawg_api_key_here

# Supabase — placeholder (Iteration 4+, see docs/06-setup/supabase-setup.md when added)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
