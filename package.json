{
  "name": "gamecup",
  "version": "0.1.0",
  "private": true,
  "description": "GameCup: World Cup of My Life Games — interactive tournament for personal game preferences",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
